# USCP 프론트엔드 환경 변수 예시
# Next.js 는 NEXT_PUBLIC_* 접두어 변수만 브라우저(클라이언트)에 노출합니다.
# 실제 값은 frontend/.env.local (gitignore) 또는 배포 시 docker-compose 로 주입합니다.

# 백엔드 API 베이스 URL (브라우저에서 호출)
NEXT_PUBLIC_API_URL=http://localhost:3810/api

# SSR/메타데이터용 사이트 베이스 URL
NEXT_PUBLIC_BASE_URL=http://localhost:3800

# 카카오맵 JavaScript 키 (지도 표시용). 미설정 시 KakaoMap 은 fallback 안내를 렌더.
# ⚠️ 코드가 읽는 변수명은 NEXT_PUBLIC_KAKAO_MAP_KEY 입니다 (KakaoMap.tsx).
#    docker-compose 는 호스트의 KAKAO_MAP_API_KEY → NEXT_PUBLIC_KAKAO_MAP_KEY 로 매핑.
NEXT_PUBLIC_KAKAO_MAP_KEY=

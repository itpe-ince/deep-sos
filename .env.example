# ============================================
# USCP v1 Environment Variables Template
# ============================================
# 복사하여 .env 파일로 저장 후 실제 값 입력

# ── Database ────────────────────────────────
POSTGRES_PASSWORD=change-this-to-strong-password

# ── JWT ─────────────────────────────────────
# 생성 예: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-random-256-bit-hex
JWT_REFRESH_SECRET_KEY=change-this-to-another-random-256-bit-hex

# ── MinIO (S3 Storage) ──────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-this-to-strong-password

# ── OAuth2 ──────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost/api/v1/auth/oauth/kakao/callback

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost/api/v1/auth/oauth/naver/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/oauth/google/callback

# ── External APIs ───────────────────────────
VMS_API_KEY=
VMS_API_URL=https://vms.or.kr/api

PORTAL_1365_API_KEY=
PORTAL_1365_API_URL=https://1365.go.kr/api

KAKAO_MAP_API_KEY=

# ── Email (SMTP) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SOS랩 USCP <noreply@univ.ac.kr>"

# ── Monitoring ──────────────────────────────
SENTRY_DSN=

# ── Environment ─────────────────────────────
ENVIRONMENT=development

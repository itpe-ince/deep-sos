# USCP v1 — 운영 환경변수 템플릿 (Sprint 5 Day 1)
#
# 사용법: 이 파일을 `.env.prod`로 복사 후 실제 값 입력
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Git에 `.env.prod`는 커밋하지 않는다 (.gitignore).

# ── 도메인 ──────────────────────────────────
SERVER_NAME=staging.uscp.local

# ── Database ────────────────────────────────
POSTGRES_PASSWORD=<운영 DB 패스워드>

# ── JWT (운영에서 반드시 재생성) ──────────────
# openssl rand -base64 48
JWT_SECRET_KEY=<운영 JWT 시크릿>
JWT_REFRESH_SECRET_KEY=<운영 JWT refresh 시크릿>

# ── MinIO ───────────────────────────────────
MINIO_ACCESS_KEY=<minio 액세스>
MINIO_SECRET_KEY=<minio 시크릿>

# ── Sentry ──────────────────────────────────
SENTRY_DSN=https://xxx@oXXXX.ingest.sentry.io/YYYY

# ── SMTP (운영 이메일 발송) ──────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=<sendgrid API 키>
SMTP_FROM=noreply@uscp.example.com

# ── VMS / 1365 (Sprint 5 단계는 mock 권장) ─
VMS_MODE=mock
# VMS_MODE=real 로 전환 시 아래 추가 필요
# PORTAL_1365_API_URL=https://api.1365.go.kr
# PORTAL_1365_API_KEY=<실제 키>

# ── OAuth (개발자센터에서 발급) ─────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Kakao Map SDK ───────────────────────────
KAKAO_MAP_API_KEY=
